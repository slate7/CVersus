# --- F01: Database & Data Layer ---
# Postgres connection string (Neon/Supabase), SSL required. See README "Database (Neon) setup".
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Guards GET /admin/export — set to a long random string and keep it secret.
ADMIN_TOKEN=changeme-generate-a-long-random-string

# Existing server port (optional; defaults to 3000).
PORT=3000

# --- F02: Google OAuth & Sessions ---
# Google OAuth 2.0 Web client (console.cloud.google.com → APIs & Services → Credentials).
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Signs session cookies — set to a long random string (see ADMIN_TOKEN generator above).
SESSION_SECRET=changeme-generate-a-long-random-string
# Base URL for the OAuth callback; must match an Authorized redirect URI in the Google client.
APP_URL=http://localhost:3000

# --- Reserved for later features — uncomment when that feature is implemented ---
# ANTHROPIC_API_KEY=           # F06
